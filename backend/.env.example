# App
APP_NAME="Agentic Notes"
DEBUG=false

# Notes storage (relative to backend dir)
NOTES_DIR=../notes

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# AI Provider: ollama | claude | gemini
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
